  "keyFeatures": [
    "YAML-based device configuration — no C++ required",
    "Supports ESP32 (all variants), ESP8266, RP2040, nRF52, BK72xx, and RTL87xx microcontrollers",
    "Seamless Home Assistant integration via native API",
    "Over-the-air (OTA) firmware updates",
    "Hundreds of built-in sensor, display, light, and actuator components",
    "Powerful automation engine with triggers, actions, and Lambdas",
    "Local control with no cloud dependency",
    "MQTT, web server, and REST/SSE API support",
    "Bluetooth proxy and BLE device support",
    "Voice assistant and media player capabilities"
  ],
  "publicApiSurface": [
    "esphome run <config> — compile and upload firmware",
    "esphome compile <config> — compile without uploading",
    "esphome upload <config> — upload pre-compiled firmware",
    "esphome logs <config> — stream device logs",
    "esphome config <config> — validate and dump config",
    "esphome dashboard — launch the web UI dashboard",
    "esphome clean <config> — clean build artifacts",
    "GET /events — Server-Sent Events for real-time state updates",
    "GET /<domain>/<id> — REST API to read entity state",
    "POST /<domain>/<id>/<action> — REST API to control entities",
    "Native API (protobuf TCP, port 6053) — used by Home Assistant & aioesphomeapi",
    "esphome: core config block",
    "wifi: / ethernet: network config blocks",
    "api: native API config block",
    "mqtt: MQTT config block",
    "ota: over-the-air update config block",
    "logger: logging config block",
    "sensor: / binary_sensor: / switch: / light: / fan: / climate: / cover: component domains",
    "on_boot / on_shutdown / on_loop automation triggers",
    "script: / interval: / globals: automation helpers"
  ]
